generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  phone         String?   @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer Customer?
  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

// ==================== CUSTOMERS ====================

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique
  groupId   String?
  company   String?
  taxId     String?  // ע.מ / ח.פ
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     CustomerGroup? @relation(fields: [groupId], references: [id])
  addresses Address[]
  orders    Order[]
  carts     Cart[]

  @@map("customers")
}

model CustomerGroup {
  id              String  @id @default(cuid())
  name            String  @unique // retail, architect, contractor, vip
  displayName     String  // קמעונאי, אדריכל, קבלן, VIP
  discountPercent Float   @default(0)
  paymentTerms    String? // שוטף+30, מזומן, etc.

  customers  Customer[]
  groupPrices GroupPrice[]

  @@map("customer_groups")
}

model Address {
  id         String  @id @default(cuid())
  customerId String
  label      String? // בית, משרד
  fullName   String
  phone      String?
  street     String
  city       String
  zipCode    String?
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@map("addresses")
}

// ==================== PRODUCTS ====================

model Supplier {
  id            String   @id @default(cuid())
  name          String   @unique
  website       String?
  scraperConfig Json?    // config for automated scraping
  contactInfo   String?
  lastSyncedAt  DateTime?
  createdAt     DateTime @default(now())

  products Product[]

  @@map("suppliers")
}

model Category {
  id       String  @id @default(cuid())
  parentId String?
  name     String
  slug     String  @unique
  image    String?
  sortOrder Int    @default(0)

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@map("categories")
}

model Product {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  description    String?
  categoryId     String?
  supplierId     String?
  supplierUrl    String?
  supplierSku    String?
  basePrice      Float         // מחיר קמעונאי ברירת מחדל
  costPrice      Float?        // מחיר עלות מהספק
  status         ProductStatus @default(DRAFT)
  seoTitle       String?
  seoDescription String?
  featured       Boolean       @default(false)
  sortOrder      Int           @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  category    Category?      @relation(fields: [categoryId], references: [id])
  supplier    Supplier?      @relation(fields: [supplierId], references: [id])
  variants    Variant[]
  images      ProductImage[]
  crossSellFrom CrossSellRule[] @relation("CrossSellFrom")
  crossSellTo   CrossSellRule[] @relation("CrossSellTo")
  groupPrices GroupPrice[]

  @@map("products")
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

model Variant {
  id            String      @id @default(cuid())
  productId     String
  name          String      // e.g. "ברונזה", "50 ס"מ"
  sku           String      @unique
  priceOverride Float?      // null = use product basePrice
  costPrice     Float?
  stockStore    Int         @default(0)  // מלאי בחנות
  stockSupplier Int         @default(0)  // מלאי אצל ספק
  stockStatus   StockStatus @default(IN_STOCK)
  weight        Float?      // kg
  sortOrder     Int         @default(0)
  isDefault     Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  images     ProductImage[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@map("variants")
}

enum StockStatus {
  IN_STOCK      // יש בחנות
  AT_SUPPLIER   // יש אצל ספק
  ON_ORDER      // צריך להזמין
  OUT_OF_STOCK  // אזל
}

model ProductImage {
  id          String  @id @default(cuid())
  productId   String
  variantId   String?
  url         String
  altText     String?
  sourceUrl   String? // URL מקורי מאתר הספק
  sortOrder   Int     @default(0)
  // true = full-bleed lifestyle/atmosphere shot → render with object-cover, no padding.
  // false = product cutout on white background → render with object-contain + padding.
  isLifestyle Boolean @default(false)

  product Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@map("product_images")
}

model GroupPrice {
  id        String @id @default(cuid())
  productId String
  groupId   String
  price     Float

  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  group   CustomerGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([productId, groupId])
  @@map("group_prices")
}

model CrossSellRule {
  id               String        @id @default(cuid())
  productId        String
  relatedProductId String
  ruleType         CrossSellType @default(MANUAL)
  score            Float         @default(1.0)

  product        Product @relation("CrossSellFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("CrossSellTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId])
  @@map("cross_sell_rules")
}

enum CrossSellType {
  MANUAL
  CATEGORY
  BEHAVIORAL
}

// ==================== CART ====================

model Cart {
  id             String    @id @default(cuid())
  customerId     String?
  sessionId      String?   @unique
  abandonedAt    DateTime?
  recoverySentAt DateTime?
  convertedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  customer Customer?  @relation(fields: [customerId], references: [id])
  items    CartItem[]

  @@map("carts")
}

model CartItem {
  id        String @id @default(cuid())
  cartId    String
  variantId String
  quantity  Int    @default(1)

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@unique([cartId, variantId])
  @@map("cart_items")
}

// ==================== ORDERS ====================

model Order {
  id             String      @id @default(cuid())
  orderNumber    String      @unique // MOD-0001
  customerId     String
  addressId      String?
  status         OrderStatus @default(PENDING)
  subtotal       Float
  discount       Float       @default(0)
  shippingCost   Float       @default(0)
  total          Float
  paymentRef     String?     // Morning transaction ref
  invoiceRef     String?     // Green Invoice ref
  shippingMethod String?
  trackingNumber String?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id])
  address  Address?    @relation(fields: [addressId], references: [id])
  items    OrderItem[]
  events   OrderEvent[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int
  unitPrice Float
  total     Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  type      String   // created, paid, shipped, delivered, cancelled
  data      Json?
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_events")
}

// ==================== ANALYTICS ====================

model PageView {
  id         String   @id @default(cuid())
  path       String
  sessionId  String?
  customerId String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@map("page_views")
}

model AuditLog {
  id         String   @id @default(cuid())
  actor      String   // yarin, system, customer email
  action     String   // product.created, order.updated, etc.
  entityType String
  entityId   String
  data       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}

model ContactMessage {
  id        String              @id @default(cuid())
  name      String
  phone     String
  email     String?
  subject   String?
  message   String
  status    ContactMessageStatus @default(NEW)
  source    String              @default("contact_form") // contact_form, footer, b2b
  ipAddress String?
  userAgent String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

enum ContactMessageStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}
